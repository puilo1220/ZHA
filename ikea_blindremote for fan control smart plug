blueprint:
  name: IKEA E1766 → Toggle Smart Plug / Fan (Zigbee2MQTT)
  description: |
    用 IKEA E1766 窗簾遙控器（Zigbee2MQTT）控制 Smart Plug 開關風扇
    上鍵 / 下鍵 皆可 Toggle（可自行選擇）
  domain: automation

  input:
    remote:
      name: IKEA E1766 Remote
      description: 選擇你的 E1766 遙控器
      selector:
        device:
          integration: mqtt
          manufacturer: IKEA

    smart_plug:
      name: Smart Plug（風扇）
      description: 選擇控制風扇的 Smart Plug
      selector:
        entity:
          domain: switch

    button_action:
      name: 使用哪個按鈕 Toggle
      description: |
        常見值（請在 Developer Tools → Events 按一下遙控器確認）：
        - open（或 up_single）
        - close（或 down_single）
      selector:
        text:

trigger:
  - platform: device
    domain: mqtt
    device_id: !input remote
    type: action
    subtype: !input button_action
    id: toggle

action:
  - service: switch.toggle
    target:
      entity_id: !input smart_plug

mode: single
