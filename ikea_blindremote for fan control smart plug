blueprint:
  name: IKEA E1766 → 分開設定開關風扇 (Zigbee2MQTT)
  description: |
    用 E1766 遙控器分開控制風扇：
    - 一個按鈕開風扇（Turn ON）
    - 另一個按鈕關風扇（Turn OFF）
  domain: automation

  input:
    remote:
      name: IKEA E1766 遙控器
      description: 選擇你的 E1766
      selector:
        device:
          integration: mqtt
          manufacturer: IKEA

    smart_plug:
      name: Smart Plug（風扇）
      selector:
        entity:
          domain: switch

    on_button:
      name: 開風扇的按鈕動作
      description: |
        例如：open、up_single、up_short
        （請先去 Developer Tools → Events 按一下按鈕確認名稱）
      selector:
        text:

    off_button:
      name: 關風扇的按鈕動作
      description: |
        例如：close、down_single、down_short
        （請先去 Developer Tools → Events 按一下按鈕確認名稱）
      selector:
        text:

trigger:
  - platform: device
    domain: mqtt
    device_id: !input remote
    type: action
    subtype: !input on_button
    id: turn_on

  - platform: device
    domain: mqtt
    device_id: !input remote
    type: action
    subtype: !input off_button
    id: turn_off

action:
  - choose:
      - conditions:
          - condition: trigger
            id: turn_on
        sequence:
          - service: switch.turn_on
            target:
              entity_id: !input smart_plug

      - conditions:
          - condition: trigger
            id: turn_off
        sequence:
          - service: switch.turn_off
            target:
              entity_id: !input smart_plug

mode: single
